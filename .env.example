# Phase 2: run `docker compose up -d db`, then `cp .env.example .env` and `npx prisma migrate dev`.
DATABASE_URL="postgresql://harbor:harbor@localhost:5432/harbor"

# Auth.js — a random value is enough for local dev (Phase 2)
AUTH_SECRET=""

# OAuth SSO providers (Phase 3) — leave blank until the user supplies real app credentials;
# Credentials (email/password) sign-in works without these.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_ENTRA_CLIENT_ID=""
MICROSOFT_ENTRA_CLIENT_SECRET=""

# Optional: a real TEAM (highest-privilege) account seeded into every workspace,
# in addition to the demo "you@yourfirm.com" account. Never commit real values here —
# only set them in your local, gitignored .env. Skipped entirely if unset.
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_NAME=""
SUPER_ADMIN_PASSWORD=""
